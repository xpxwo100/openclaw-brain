{
  "id": "brain-prompt",
  "name": "Brain Prompt Injector",
  "description": "Injects compact recalled memory context before prompt build.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "backend": { "type": "string", "enum": ["jsonl", "lancedb"] },
      "limit": { "type": "integer", "minimum": 1, "maximum": 20 },
      "recentWindow": { "type": "integer", "minimum": 1, "maximum": 50 },
      "minQueryLength": { "type": "integer", "minimum": 1, "maximum": 50 },
      "maxChars": { "type": "integer", "minimum": 100, "maximum": 10000 },
      "maxEstimatedTokens": { "type": "integer", "minimum": 32, "maximum": 4000 },
      "heading": { "type": "string" }
    }
  }
}
